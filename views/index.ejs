<%- include('partials/header') %>

    <section class="hero">
        <div class="hero-content"
            style="display: flex; max-width: 1200px; width: 100%; align-items: center; justify-content: space-between; padding: 0 2rem; gap: 2rem; text-align: left;">
            <div class="hero-text" style="flex: 1;">
                <h1>Welcome to EduPort</h1>
                <p>Your Gateway to Quality Education and Bright Future</p>
                <a href="/courses" class="btn">Explore Courses</a>
            </div>
            <div class="hero-image" style="flex: 1; text-align: right;">
                <img src="/images/home.png" alt="EduPort Home"
                    style="max-width: 100%; max-height: 500px; border-radius: 12px; box-shadow: 0 20px 40px rgba(0,0,0,0.3); object-fit: cover;">
            </div>
        </div>
    </section>

    <div class="container">
        <div class="section-title">Why Choose Us?</div>
        <div class="grid">
            <div class="card">
                <h3>Experienced Faculty</h3>
                <p>Learn from industry experts and experienced professors dedicated to your success.</p>
            </div>
            <div class="card">
                <h3>Modern Campus</h3>
                <p>State-of-the-art facilities and labs to support your academic journey.</p>
            </div>
            <div class="card">
                <h3>Placement Support</h3>
                <p>Dedicated placement cell to help you secure your dream job.</p>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>